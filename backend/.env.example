# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Nakshatra Lending API
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nakshatra
# Docker (use service name instead of localhost):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nakshatra

# ── Blockchain ────────────────────────────────────────────────────────────────
# Local dev:
RPC_URL=http://127.0.0.1:8545
# Docker:
# RPC_URL=http://hardhat:8545
CHAIN_ID=31337

# Paste addresses printed by: npx hardhat run scripts/deploy.js --network localhost
USDC_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
USER_PROFILE_NFT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
LOAN_FACTORY_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
ESCROW_ADDRESS=0xDc64a140Aa3E981100a9becA4E685f962f0cF6C9
REPUTATION_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

# Deployer = wallet[0] from `npx hardhat node` output
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── IPFS ──────────────────────────────────────────────────────────────────────
# Local dev:
IPFS_API_URL=http://127.0.0.1:5001
# Docker:
# IPFS_API_URL=http://ipfs:5001
PINATA_API_KEY=
PINATA_SECRET_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── AI Services ───────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
